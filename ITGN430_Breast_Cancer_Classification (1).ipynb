   "source": [
    "# ─── Encode Target Variable ───────────────────────────────────────────────────\n",
    "# B (Benign) = 0, M (Malignant) = 1\n",
    "le = LabelEncoder()\n",
    "df['y_encoded'] = le.fit_transform(df['y'])   # B→0, M→1\n",
    "\n",
    "print(\"Label Encoding:\")\n",
    "for cls, enc in zip(le.classes_, le.transform(le.classes_)):\n",
    "    print(f\"  {cls} → {enc}\")\n",
    "\n",
    "# ─── Separate Features and Target ─────────────────────────────────────────────\n",
    "X = df.drop(columns=['y', 'y_encoded'])\n",
    "y = df['y_encoded']\n",
    "\n",
    "print(f\"\\n  Feature matrix X shape : {X.shape}\")\n",
    "print(f\"  Target vector y shape  : {y.shape}\")"
   ]
  },
