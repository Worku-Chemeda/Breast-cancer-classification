      "  Train class dist : {0: 285, 1: 170} (0=B, 1=M)\n",
      "  Test class dist  : {0: 72, 1: 42}\n"
     ]
    }
   ],
   "source": [
    "# ─── Train/Test Split (80/20, Stratified) ─────────────────────────────────────\n",
    "# IMPORTANT: Split BEFORE scaling to prevent data leakage.\n",
    "# Stratify ensures both splits maintain the original class ratio.\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X, y, test_size=0.20, random_state=42, stratify=y\n",
    ")\n",
    "\n",
    "print(\"Train/Test Split (80% / 20%) — Stratified:\")\n",
    "print(f\"  Training set   : {X_train.shape[0]} samples\")\n",
    "print(f\"  Test set       : {X_test.shape[0]} samples\")\n",
    "print(f\"  Train class dist : {pd.Series(y_train).value_counts().to_dict()} (0=B, 1=M)\")\n",
    "print(f\"  Test class dist  : {pd.Series(y_test).value_counts().to_dict()}\")"
   ]
